# Generated by goplt init (go-library-simple / [[.Complexity]])
description = "[[.Description]]"
target-dir  = "{{.Name}}"

[variables]

[variables.name]
kind        = "input"
required    = true
description = "Library name"

[variables.org-prefix]
kind        = "input"
value       = "github.com/acme"
description = "Module path prefix"

[variables.license]
kind        = "stringChoice"
value       = ["MIT", "Apache-2.0", "GPL-3.0", "BSD-3-Clause"]
description = "License to apply"
